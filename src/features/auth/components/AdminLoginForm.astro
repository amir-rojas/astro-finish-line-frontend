---
---

<form class="form" method="POST" action="/api/admin/auth" novalidate>

  <div class="field">
    <label for="email" class="label"><span class="num">01</span>Correo electrónico</label>
    <div class="control">
      <input
        type="email"
        id="email"
        name="email"
        class="input"
        placeholder="admin@finishline.bo"
        autocomplete="email"
        required
      />
    </div>
  </div>

  <div class="field">
    <div class="label-row">
      <label for="password" class="label"><span class="num">02</span>Contraseña</label>
      <a href="/admin/reset" class="forgot">¿Olvidaste tu contraseña?</a>
    </div>
    <div class="control">
      <input
        type="password"
        id="password"
        name="password"
        class="input"
        placeholder="••••••••••••"
        autocomplete="current-password"
        required
      />
      <button type="button" id="togglePwd" class="toggle-btn" aria-label="Mostrar contraseña" aria-pressed="false">
        <svg id="eyeShow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
        </svg>
        <svg id="eyeHide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" style="display:none" aria-hidden="true">
          <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
          <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
          <line x1="1" y1="1" x2="23" y2="23"/>
        </svg>
      </button>
    </div>
  </div>

  <button type="submit" class="submit-btn">
    <span>Ingresar</span>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </button>

</form>

<style>
  .form {
    display: flex;
    flex-direction: column;
    gap: 26px;
  }

  /* staggered reveal — one orchestrated entrance */
  .field,
  .submit-btn {
    animation: field-in 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .field:nth-of-type(1) { animation-delay: 0.06s; }
  .field:nth-of-type(2) { animation-delay: 0.13s; }
  .submit-btn { animation-delay: 0.2s; }

  @keyframes field-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .label {
    display: flex;
    align-items: center;
    gap: 9px;
    font-family: 'Barlow', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #0d1b3e;
    transition: color 0.2s;
  }

  .label .num {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    color: #e8461a;
    font-size: 14px;
    letter-spacing: 0;
    line-height: 1;
  }

  .label-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }

  .forgot {
    font-family: 'Barlow', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: #e8461a;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .forgot:hover { opacity: 0.65; }
  .forgot:focus-visible,
  .toggle-btn:focus-visible {
    outline: 2px solid #e8461a;
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* ── input control: flat underline + animated accent fill ── */
  .control {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 2px solid #cbd5e1;
    border-radius: 0;
    padding: 9px 0;
    font-family: 'Barlow', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #0d1b3e;
    outline: none;
    transition: border-color 0.2s;
  }
  .input::placeholder { color: #94a3b8; font-weight: 400; }

  /* the accent line wipes in from the left on focus */
  .control::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 2px;
    background: #e8461a;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .control:focus-within::after { transform: scaleX(1); }

  /* lift the field heading while editing */
  .field:focus-within .label { color: #e8461a; }

  /* keep room for the toggle on the password field */
  .control:has(.toggle-btn) .input { padding-right: 36px; }

  .toggle-btn {
    position: absolute;
    right: 0;
    bottom: 9px;
    background: none;
    border: none;
    cursor: pointer;
    color: #94a3b8;
    padding: 2px;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .toggle-btn:hover { color: #0d1b3e; }
  .toggle-btn svg { width: 18px; height: 18px; }

  /* ── flat squared button — swiss ── */
  .submit-btn {
    width: 100%;
    position: relative;
    overflow: hidden;
    background: #e8461a;
    color: #ffffff;
    border: none;
    border-radius: 0;
    padding: 17px;
    margin-top: 6px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: 4px;
    text-transform: uppercase;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    transition: background 0.2s, transform 0.1s, box-shadow 0.2s;
  }
  .submit-btn > span,
  .submit-btn > svg { position: relative; z-index: 1; }
  .submit-btn svg { width: 19px; height: 19px; transition: transform 0.2s; }

  /* navy sweep on hover */
  .submit-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #0d1b3e;
    transform: translateX(-101%);
    transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 0;
  }
  .submit-btn:hover::before { transform: translateX(0); }
  .submit-btn:hover { box-shadow: 0 10px 24px -12px rgba(13, 27, 62, 0.5); }
  .submit-btn:hover svg { transform: translateX(5px); }
  .submit-btn:active { transform: translateY(1px); }
  .submit-btn:focus-visible {
    outline: 2px solid #0d1b3e;
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .field,
    .submit-btn,
    .submit-btn::before,
    .submit-btn svg,
    .control::after { animation: none; transition: none; }
  }
</style>

<script>
  const btn = document.getElementById('togglePwd') as HTMLButtonElement;
  const input = document.getElementById('password') as HTMLInputElement;
  const eyeShow = document.getElementById('eyeShow') as unknown as SVGElement;
  const eyeHide = document.getElementById('eyeHide') as unknown as SVGElement;

  btn?.addEventListener('click', () => {
    const isPassword = input.type === 'password';
    input.type = isPassword ? 'text' : 'password';
    eyeShow.style.display = isPassword ? 'none' : '';
    eyeHide.style.display = isPassword ? '' : 'none';
    btn.setAttribute('aria-pressed', String(isPassword));
    btn.setAttribute('aria-label', isPassword ? 'Ocultar contraseña' : 'Mostrar contraseña');
  });
</script>
