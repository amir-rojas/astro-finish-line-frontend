---
---

<form class="form" method="POST" action="/api/admin/auth" novalidate>

  <div class="field">
    <label for="email" class="label">Correo Electrónico</label>
    <div class="input-wrap">
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
        <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/>
      </svg>
      <input
        type="email"
        id="email"
        name="email"
        class="input"
        placeholder="admin@finishline.bo"
        autocomplete="email"
      />
    </div>
  </div>

  <div class="field">
    <div class="label-row">
      <label for="password" class="label">Contraseña</label>
      <a href="/admin/reset" class="forgot">¿Olvidaste tu contraseña?</a>
    </div>
    <div class="input-wrap">
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
        <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      <input
        type="password"
        id="password"
        name="password"
        class="input"
        placeholder="••••••••••••"
        autocomplete="current-password"
      />
      <button type="button" id="togglePwd" class="toggle-btn" aria-label="Mostrar contraseña">
        <svg id="eyeShow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
        </svg>
        <svg id="eyeHide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" style="display:none">
          <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
          <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
          <line x1="1" y1="1" x2="23" y2="23"/>
        </svg>
      </button>
    </div>
  </div>

  <label class="remember">
    <input type="checkbox" name="remember" />
    <span>Mantener sesión activa</span>
  </label>

  <button type="submit" class="submit-btn">
    INGRESAR
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </button>

</form>

<style>
  .form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .label {
    font-family: 'Barlow', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: #64748b;
  }

  .label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .forgot {
    font-family: 'Barlow', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #e8461a;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .forgot:hover { opacity: 0.75; }

  .input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .icon {
    position: absolute;
    left: 13px;
    width: 15px;
    height: 15px;
    color: #94a3b8;
    pointer-events: none;
    flex-shrink: 0;
  }

  .input {
    width: 100%;
    background: #f8fafc;
    border: 1.5px solid #e2e8f0;
    border-radius: 8px;
    padding: 12px 14px 12px 40px;
    font-family: 'Barlow', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #0d1b3e;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    box-sizing: border-box;
  }

  .input::placeholder { color: #94a3b8; }

  .input:focus {
    border-color: #e8461a;
    box-shadow: 0 0 0 3px rgba(232, 70, 26, 0.1);
    background: #ffffff;
  }

  .toggle-btn {
    position: absolute;
    right: 12px;
    background: none;
    border: none;
    cursor: pointer;
    color: #94a3b8;
    padding: 4px;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .toggle-btn:hover { color: #475569; }
  .toggle-btn svg { width: 15px; height: 15px; }

  .remember {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Barlow', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #64748b;
    cursor: pointer;
    user-select: none;
  }
  .remember input[type="checkbox"] {
    accent-color: #e8461a;
    cursor: pointer;
    width: 14px;
    height: 14px;
    margin: 0;
  }

  .submit-btn {
    width: 100%;
    background: #e8461a;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    padding: 14px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 19px;
    font-weight: 700;
    letter-spacing: 3px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: background 0.2s, box-shadow 0.2s, transform 0.1s;
    box-shadow: 0 4px 16px rgba(232, 70, 26, 0.28);
  }
  .submit-btn svg { width: 17px; height: 17px; }

  .submit-btn:hover {
    background: #c73a15;
    box-shadow: 0 6px 24px rgba(232, 70, 26, 0.38);
    transform: translateY(-1px);
  }
  .submit-btn:active { transform: translateY(0); }
</style>

<script>
  const btn = document.getElementById('togglePwd') as HTMLButtonElement;
  const input = document.getElementById('password') as HTMLInputElement;
  const eyeShow = document.getElementById('eyeShow') as unknown as SVGElement;
  const eyeHide = document.getElementById('eyeHide') as unknown as SVGElement;

  btn?.addEventListener('click', () => {
    const isPassword = input.type === 'password';
    input.type = isPassword ? 'text' : 'password';
    eyeShow.style.display = isPassword ? 'none' : '';
    eyeHide.style.display = isPassword ? '' : 'none';
  });
</script>
