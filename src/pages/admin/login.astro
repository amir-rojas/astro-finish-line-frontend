---
import BaseLayout from '../../shared/layouts/BaseLayout.astro';
import AdminLoginForm from '../../features/auth/components/AdminLoginForm.astro';
import { Image } from 'astro:assets';
import logo from '../../assets/images/logo.jpg';

/* ── One-point perspective track (background → foreground) ──
   A straight running track in 1-point perspective: it is born at a
   vanishing point near the top-center and fans out toward the bottom,
   bleeding off the sides in the foreground. Lane stripes are tapered
   triangles (a point at the vanishing point, a small base in front),
   so they read as receding lines. */
const VB_W = 1200;
const VB_H = 1000;

const VP: [number, number] = [600, 96]; // vanishing point — top center
const BOTTOM_Y = VB_H;                   // foreground edge
const ROAD_HALF = 760;                   // half-width at the foreground (bleeds off the sides)

const leftX = VP[0] - ROAD_HALF;
const rightX = VP[0] + ROAD_HALF;

// filled road: a triangle from the vanishing point to the wide foreground
const trackFill = `M${VP[0]} ${VP[1]} L${leftX.toFixed(1)} ${BOTTOM_Y} L${rightX.toFixed(1)} ${BOTTOM_Y} Z`;

// tapered white lane stripes converging at the vanishing point
const LANES = 9;
const STRIPE_HALF = 7; // half-width of a stripe at the foreground
const laneStripes: string[] = [];
for (let i = 1; i < LANES; i++) {
  const bx = leftX + (i / LANES) * (rightX - leftX);
  laneStripes.push(
    `M${VP[0]} ${VP[1]} L${(bx - STRIPE_HALF).toFixed(1)} ${BOTTOM_Y} L${(bx + STRIPE_HALF).toFixed(1)} ${BOTTOM_Y} Z`
  );
}
---

<BaseLayout title="Acceso Administrativo">
  <main class="page">

    <!-- ─── PERSPECTIVE TRACK (full-bleed backdrop) ──────────── -->
    <svg
      class="track"
      viewBox={`0 0 ${VB_W} ${VB_H}`}
      preserveAspectRatio="xMidYMin slice"
      aria-hidden="true"
    >
      <defs>
        <!-- pale at the far distance → vivid orange in the foreground -->
        <linearGradient id="road" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"  stop-color="#fdeae2" />
          <stop offset="50%" stop-color="#f4ad95" />
          <stop offset="100%" stop-color="#e8461a" />
        </linearGradient>
      </defs>

      <path d={trackFill} fill="url(#road)" />
      {laneStripes.map((d) => (
        <path d={d} fill="#ffffff" opacity="0.85" />
      ))}
    </svg>

    <!-- ─── CENTERED CONTENT ─────────────────────────────────── -->
    <section class="content">

      <header class="brand">
        <div class="logo-wrap">
          <Image src={logo} alt="Finish Line Sporting Events" width={120} height={120} quality={90} />
        </div>
        <div class="wordmark">
          <span class="brand-name">Finish</span>
          <span class="brand-name accent">Line</span>
        </div>
        <span class="brand-sub">Sporting Events</span>
      </header>

      <h1 class="title">Inicia<br />sesión</h1>

      <AdminLoginForm />

    </section>

  </main>
</BaseLayout>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #ffffff; }
</style>

<style>
  .page {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 1.5rem;
    /* clip the track's horizontal bleed, but let tall content scroll */
    overflow-x: clip;
    font-family: 'Barlow', sans-serif;
    background: #ffffff;
  }

  /* perspective track — fills the whole screen, anchored to the top so the
     vanishing point stays visible on tall screens */
  .track {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  /* ── CENTERED CONTENT ── */
  .content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 400px;
    display: flex;
    flex-direction: column;
    animation: rise 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* soft white halo so the form reads cleanly over the orange road */
  .content::before {
    content: '';
    position: absolute;
    inset: -72px -96px;
    background: radial-gradient(
      closest-side,
      rgba(255, 255, 255, 0.97) 62%,
      rgba(255, 255, 255, 0) 100%
    );
    z-index: -1;
    pointer-events: none;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .content { animation: none; }
  }

  /* ── BRAND ── */
  .brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 30px;
  }

  .logo-wrap {
    width: 72px;
    height: 72px;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 16px;
    box-shadow: 0 0 0 1px rgba(13, 27, 62, 0.08);
  }
  .logo-wrap :global(img) {
    width: 100%; height: 100%;
    object-fit: contain; display: block;
  }

  .wordmark {
    display: flex;
    gap: 10px;
    align-items: baseline;
  }
  .brand-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(34px, 7vw, 46px);
    font-weight: 800;
    color: #0d1b3e;
    line-height: 0.86;
    letter-spacing: -1px;
    text-transform: uppercase;
  }
  .brand-name.accent { color: #e8461a; }

  .brand-sub {
    font-family: 'Barlow', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: #64748b;
    margin-top: 10px;
  }

  /* ── TITLE ── */
  .title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(38px, 5vw, 50px);
    font-weight: 800;
    color: #0d1b3e;
    line-height: 0.9;
    letter-spacing: -1px;
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 32px;
  }

  /* ── MOBILE — same idea, tighter ── */
  @media (max-width: 600px) {
    .page {
      padding: 7vh 1.4rem 3rem;
      align-items: flex-start;
    }
    .content {
      max-width: 420px;
      margin: auto;
    }
    .content::before {
      inset: -44px -40px;
      background: radial-gradient(
        closest-side,
        rgba(255, 255, 255, 0.97) 58%,
        rgba(255, 255, 255, 0) 100%
      );
    }
    .brand { margin-bottom: 26px; }
    .logo-wrap { width: 64px; height: 64px; }
    .title { margin-bottom: 28px; }
  }

  @media (max-width: 380px) {
    .content::before { inset: -32px -24px; }
  }
</style>
