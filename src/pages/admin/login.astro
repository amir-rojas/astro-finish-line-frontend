---
// Server-rendered: necesitamos leer el query param `error` por petición.
export const prerender = false;

import BaseLayout from '../../shared/layouts/BaseLayout.astro';
import AdminLoginForm from '../../features/auth/components/AdminLoginForm.astro';
import { Image } from 'astro:assets';
import logo from '../../assets/images/logo.jpg';

// Mensaje de error según lo que devolvió el endpoint /api/admin/auth.
const ERROR_MESSAGES: Record<string, string> = {
  missing: 'Completa tu correo y contraseña.',
  invalid: 'Correo o contraseña incorrectos.',
  server: 'No pudimos conectar con el servidor. Intenta de nuevo.',
};
const errorCode = Astro.url.searchParams.get('error');
const errorMessage = errorCode ? (ERROR_MESSAGES[errorCode] ?? 'Ocurrió un error.') : null;

/* ── One-point perspective track (background → foreground) ──
   A straight running track in 1-point perspective for the LEFT panel:
   born at a vanishing point near the top-center and fanning out toward
   the bottom, bleeding off the sides in the foreground. Lane stripes are
   tapered triangles (a point at the vanishing point, a small base in
   front), so they read as receding lines. The viewBox is portrait to
   match the tall left column. */
const VB_W = 820;
const VB_H = 1120;

const VP: [number, number] = [410, 70]; // vanishing point — top center
const BOTTOM_Y = VB_H;                  // foreground edge
const ROAD_HALF = 560;                  // half-width at the foreground (bleeds off the sides)

const leftX = VP[0] - ROAD_HALF;
const rightX = VP[0] + ROAD_HALF;

// filled road: a triangle from the vanishing point to the wide foreground
const trackFill = `M${VP[0]} ${VP[1]} L${leftX.toFixed(1)} ${BOTTOM_Y} L${rightX.toFixed(1)} ${BOTTOM_Y} Z`;

// tapered white lane stripes converging at the vanishing point
const LANES = 9;
const STRIPE_HALF = 6; // half-width of a stripe at the foreground
const laneStripes: string[] = [];
for (let i = 1; i < LANES; i++) {
  const bx = leftX + (i / LANES) * (rightX - leftX);
  laneStripes.push(
    `M${VP[0]} ${VP[1]} L${(bx - STRIPE_HALF).toFixed(1)} ${BOTTOM_Y} L${(bx + STRIPE_HALF).toFixed(1)} ${BOTTOM_Y} Z`
  );
}

/* ── Finish line (checkered band) — the brand made literal ──
   A 2-row checkerboard laid across the track in perspective near the
   foreground. Horizontal lines stay horizontal on screen; the road's
   half-width shrinks toward the vanishing point, so columns narrow with
   distance and the band reads as lying flat on the track. */
const halfAt = (y: number) => ROAD_HALF * (y - VP[1]) / (BOTTOM_Y - VP[1]);
const xAt = (y: number, frac: number) => VP[0] + (frac * 2 - 1) * halfAt(y);

const FL_TOP = 742;
const FL_BOT = 838;
const FL_MID = (FL_TOP + FL_BOT) / 2;
const FL_COLS = 16;
const finishCells: { d: string; color: string }[] = [];
for (let r = 0; r < 2; r++) {
  const yA = r === 0 ? FL_TOP : FL_MID;
  const yB = r === 0 ? FL_MID : FL_BOT;
  for (let c = 0; c < FL_COLS; c++) {
    const f0 = c / FL_COLS;
    const f1 = (c + 1) / FL_COLS;
    const color = (r + c) % 2 === 0 ? '#ffffff' : '#0d1b3e';
    finishCells.push({
      d: `M${xAt(yA, f0).toFixed(1)} ${yA} L${xAt(yA, f1).toFixed(1)} ${yA} L${xAt(yB, f1).toFixed(1)} ${yB} L${xAt(yB, f0).toFixed(1)} ${yB} Z`,
      color,
    });
  }
}
---

<BaseLayout title="Acceso Administrativo">
  <main class="page">

    <!-- ─── LEFT: BRAND + PERSPECTIVE TRACK ──────────────────── -->
    <aside class="visual">

      <svg
        class="track"
        viewBox={`0 0 ${VB_W} ${VB_H}`}
        preserveAspectRatio="xMidYMin slice"
        aria-hidden="true"
      >
        <defs>
          <!-- pale at the far distance → vivid orange in the foreground -->
          <linearGradient id="road" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%"  stop-color="#fdeae2" />
            <stop offset="50%" stop-color="#f4ad95" />
            <stop offset="100%" stop-color="#e8461a" />
          </linearGradient>
        </defs>

        <path d={trackFill} fill="url(#road)" />
        {laneStripes.map((d) => (
          <path d={d} fill="#ffffff" opacity="0.85" />
        ))}
        {finishCells.map((c) => (
          <path d={c.d} fill={c.color} />
        ))}
      </svg>

      <header class="brand">
        <div class="logo-wrap">
          <Image src={logo} alt="Finish Line Sporting Events" width={120} height={120} quality={90} />
        </div>
        <div class="wordmark">
          <span class="brand-name">Finish</span>
          <span class="brand-name accent">Line</span>
        </div>
        <span class="brand-sub">Sporting Events</span>
      </header>

    </aside>

    <!-- ─── RIGHT: FORM PANEL ────────────────────────────────── -->
    <section class="panel">
      <div class="panel-inner">

        <span class="eyebrow"><i class="eyebrow-bar"></i>Panel administrativo</span>
        <h1 class="title">Inicia<br />sesión</h1>
        <p class="subtitle">Accede a tu panel de control y gestiona tus eventos deportivos.</p>

        {errorMessage && (
          <div class="alert" role="alert">{errorMessage}</div>
        )}

        <AdminLoginForm />

      </div>
    </section>

  </main>
</BaseLayout>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; }
  body { background: #ffffff; }
</style>

<style>
  /* two-column split: visual rail + form panel */
  .page {
    min-height: 100vh;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    font-family: 'Barlow', sans-serif;
    background: #ffffff;
  }

  /* ── LEFT: VISUAL ── */
  .visual {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(32px, 4vw, 64px);
    /* warm wash so the flanks of the track aren't dead white */
    background:
      radial-gradient(120% 80% at 50% 8%, #ffffff 0%, #fff6f1 55%, #fdeae2 100%);
  }
  /* hairline seam between the two halves */
  .visual::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 1px;
    height: 100%;
    background: rgba(13, 27, 62, 0.08);
    z-index: 2;
  }

  /* perspective track — fills the left rail, anchored to the top so the
     vanishing point stays visible on tall screens */
  .track {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  /* ── BRAND (top of the rail, over the pale distance) ── */
  .brand {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    animation: rise 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .logo-wrap {
    width: 72px;
    height: 72px;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 18px;
    background: #ffffff;
    box-shadow: 0 0 0 1px rgba(13, 27, 62, 0.08), 0 8px 24px -16px rgba(13, 27, 62, 0.4);
  }
  .logo-wrap :global(img) {
    width: 100%; height: 100%;
    object-fit: contain; display: block;
  }

  .wordmark {
    display: flex;
    gap: 12px;
    align-items: baseline;
  }
  .brand-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(40px, 5.5vw, 64px);
    font-weight: 800;
    color: #0d1b3e;
    line-height: 0.86;
    letter-spacing: -1px;
    text-transform: uppercase;
  }
  .brand-name.accent { color: #e8461a; }

  .brand-sub {
    font-family: 'Barlow', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: #64748b;
    margin-top: 12px;
  }

  /* ── RIGHT: FORM PANEL ── */
  .panel {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(32px, 5vw, 72px) clamp(24px, 4vw, 64px);
    background: #ffffff;
  }
  .panel-inner {
    width: 100%;
    max-width: 420px;
    animation: rise 0.45s 0.08s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* ── EYEBROW ── */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: 'Barlow', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #e8461a;
    margin-bottom: 18px;
  }
  .eyebrow-bar {
    width: 28px;
    height: 3px;
    background: #e8461a;
    display: inline-block;
  }

  .title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(40px, 5vw, 54px);
    font-weight: 800;
    color: #0d1b3e;
    line-height: 0.9;
    letter-spacing: -1px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .subtitle {
    font-family: 'Barlow', sans-serif;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.5;
    color: #64748b;
    margin-bottom: 36px;
    max-width: 36ch;
  }

  /* ── ERROR BANNER ── */
  .alert {
    margin: -8px 0 24px;
    padding: 12px 16px;
    background: #fdeae2;
    border-left: 3px solid #e8461a;
    font-family: 'Barlow', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #0d1b3e;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .brand, .panel-inner { animation: none; }
  }

  /* ── TABLET: narrow the visual rail ── */
  @media (max-width: 900px) {
    .page { grid-template-columns: 0.85fr 1fr; }
  }

  /* ── MOBILE: stack — visual banner on top, form below ── */
  @media (max-width: 680px) {
    .page {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr;
    }
    .visual {
      min-height: 32vh;
      padding: clamp(28px, 8vw, 44px) 1.6rem;
      justify-content: flex-start;
    }
    .logo-wrap { width: 60px; height: 60px; margin-bottom: 14px; }
    .panel {
      align-items: flex-start;
      padding: clamp(28px, 9vw, 44px) 1.6rem 3rem;
    }
    .panel-inner { max-width: 440px; margin: 0 auto; }
    .subtitle { margin-bottom: 30px; }
  }
</style>
