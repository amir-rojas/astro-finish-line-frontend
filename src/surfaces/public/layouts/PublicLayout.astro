---
// PublicLayout — chrome de la SUPERFICIE pública (todo lo de cara al usuario:
// home/landing, eventos, inscripción, resultados...). Compone sobre BaseLayout
// (el shell <html> con metas compartidas) y aplica el lenguaje visual público:
// fuentes Archivo / Archivo Black / Space Mono, lienzo navy y color crema.
// El panel admin usa su propio AdminLayout; nunca se mezclan.
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import '../styles/public.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
  canonical?: string;
}
const { title, description, ogImage, ogUrl, canonical } = Astro.props;
---

<BaseLayout {title} {description} {ogImage} {ogUrl} {canonical}>
  {/* Fuentes propias del surface público, inyectadas en el <head> del shell. */}
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=Archivo+Black&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div data-surface="public" class="public-surface">
    <slot />
  </div>
</BaseLayout>

<script>
  // Revelado al entrar en viewport. Solo se activa con JS y si el usuario no
  // pidió reducir movimiento: por defecto el contenido es visible (no-JS safe).
  const root = document.querySelector<HTMLElement>('.public-surface');
  const allowMotion = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;

  if (root && allowMotion && 'IntersectionObserver' in window) {
    root.classList.add('reveal-ready');
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-in');
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.12 },
    );
    const els = Array.from(root.querySelectorAll<HTMLElement>('[data-reveal]'));
    // Doble rAF: se pinta el estado oculto y recién después se revela, para que
    // la transición corra. Lo que ya está en la primera pantalla (hero completo,
    // incluido el contador al borde inferior) entra al cargar; el resto, al scroll.
    requestAnimationFrame(() =>
      requestAnimationFrame(() => {
        for (const el of els) {
          const rect = el.getBoundingClientRect();
          const inView = rect.top < window.innerHeight && rect.bottom > 0;
          if (inView) el.classList.add('is-in');
          else io.observe(el);
        }
      }),
    );
  }
</script>

<style>
  .public-surface {
    --fl-navy: #0e1c30;
    --fl-ink: #14233a;
    --fl-orange: #ee5314; /* acento de marca: mark, motivos, foco (no texto blanco encima) */
    --fl-orange-strong: #cf3f0d; /* naranja para superficies con texto blanco: 4.8:1 AA */
    --fl-orange-hover: #b8380b; /* hover de CTAs primarios (texto blanco) */
    --fl-cream: #f6f0e4;
    --fl-cream-2: #efe7d6;
    --fl-cream-3: #e1d6bd;
    --fl-surface: #ffffff;
    --fl-container: 1180px;

    background: var(--fl-navy);
    color: var(--fl-cream);
    font-family: 'Archivo', system-ui, sans-serif;
    /* `clip` recorta el desborde horizontal SIN crear contenedor de scroll;
       `hidden` forzaría overflow-y:auto y rompería el position:sticky del header. */
    overflow-x: clip;
  }
</style>
