---
import type { EventData } from '../format';

interface Props {
  event: EventData;
}
const { event } = Astro.props;
const reg = event.registrationUrl;
const price = event.price;
---

{
  price && (
    <section class="price">
      <div class="price__flag price__flag--top" aria-hidden="true" />
      <div class="price__lines" aria-hidden="true" />
      <div class="price__inner">
        <p class="price__eyebrow" data-reveal>
          Inscripciones abiertas · Costo único
        </p>
        <div class="price__amount" data-reveal data-delay="1">
          {price.amount}
          <span class="price__currency">{price.currency}</span>
        </div>
        {event.includes.length > 0 && (
          <div class="price__chips" data-reveal data-delay="2">
            {event.includes.map((c) => (
              <span class="chip">{c}</span>
            ))}
          </div>
        )}
        {reg && (
          <a
            class="btn btn--primary"
            href={reg}
            target="_blank"
            rel="noopener noreferrer"
            data-reveal
            data-delay="3"
          >
            Inscribirse en Eventrid <span class="btn__arrow" aria-hidden="true">→</span>
          </a>
        )}
      </div>
      <div class="price__flag price__flag--bottom" aria-hidden="true" />
    </section>
  )
}

<style>
  .price {
    position: relative;
    overflow: hidden;
    background: var(--fl-navy);
    color: var(--fl-cream);
    text-align: center;
  }
  .price__flag {
    height: 16px;
    background: repeating-linear-gradient(
      135deg,
      var(--fl-orange) 0 14px,
      var(--fl-navy) 14px 28px
    );
  }
  /* Banda de hairlines = cronómetro / timing strip detrás del número. */
  .price__lines {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    height: clamp(150px, 26vw, 320px);
    background: repeating-linear-gradient(
      180deg,
      rgba(238, 83, 20, 0.07) 0 1px,
      transparent 1px 13px
    );
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 18%, #000 82%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 18%, #000 82%, transparent);
    pointer-events: none;
  }
  .price__inner {
    position: relative;
    max-width: var(--fl-container);
    margin: 0 auto;
    padding: clamp(50px, 8vw, 104px) clamp(20px, 5vw, 56px);
  }
  .price__eyebrow {
    margin: 0;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--fl-orange);
  }
  .price__amount {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(130px, 25vw, 310px);
    line-height: 0.8;
    letter-spacing: -0.05em;
    margin: 14px 0 0;
  }
  .price__currency {
    color: var(--fl-orange);
    font-size: 0.42em;
    letter-spacing: -0.02em;
  }
  .price__chips {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 18px;
  }
  .chip {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    border: 1px solid rgba(246, 240, 228, 0.25);
    padding: 9px 16px;
    color: #cdd7e2;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 30px;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 17px 30px;
    text-decoration: none;
    transition:
      transform 180ms var(--ease-out),
      background-color 180ms var(--ease-out);
  }
  .btn--primary {
    background: var(--fl-orange);
    color: #fff;
  }
  .btn__arrow {
    transition: transform 180ms var(--ease-out);
  }
  @media (hover: hover) {
    .btn--primary:hover {
      transform: translateY(-2px);
      background: #ff5e1d;
    }
    .btn:hover .btn__arrow {
      transform: translateX(4px);
    }
  }
  .btn:active {
    transform: scale(0.97);
  }
</style>
