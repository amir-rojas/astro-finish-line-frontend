---
// Sección combinada de INSCRIPCIÓN: el precio se presenta como un DORSAL de
// carrera (ficha acotada con encabezado de evento, banda de meta a cuadros,
// número de pecho y filas etiqueta→valor), y debajo las categorías como info
// práctica del mismo clúster. Lleva id="categorias" para el ancla del nav.
import type { EventData } from '../format';
import { dayMonth } from '../format';

interface Props {
  event: EventData;
}
const { event } = Astro.props;
const reg = event.registrationUrl;
const price = event.price;
const distance = event.distances[0] ?? '';
const year = event.date.getUTCFullYear();
const deadline = event.registrationDeadline;
---

<section id="categorias" class="enroll">
  <div class="enroll__inner">
    {
      price && (
        <div class="bib" data-reveal>
          <header class="bib__head">
            <h2 class="bib__tag">Inscripción</h2>
            <span class="bib__event">
              {event.title} · {year}
            </span>
          </header>

          <div class="bib__flag" aria-hidden="true" />

          <div class="bib__body">
            <div class="bib__num" data-reveal data-delay="1">
              <p class="bib__eyebrow">Costo único</p>
              <p class="amount">
                <span class="amount__num">{price.amount}</span>
                <span class="amount__cur">{price.currency}</span>
              </p>
            </div>

            <dl class="bib__rows" data-reveal data-delay="2">
              {event.includes.length > 0 && (
                <div class="row">
                  <dt class="row__k">Incluye</dt>
                  <dd class="row__v">
                    <ul class="incl">
                      {event.includes.map((c) => (
                        <li class="incl__item">{c}</li>
                      ))}
                    </ul>
                  </dd>
                </div>
              )}
              {deadline && (
                <div class="row">
                  <dt class="row__k">Cierre</dt>
                  <dd class="row__v">
                    {dayMonth(deadline)} {year}
                    {event.registrationNote && (
                      <span class="row__sub"> · {event.registrationNote}</span>
                    )}
                  </dd>
                </div>
              )}
            </dl>
          </div>

          {reg && (
            <a
              class="btn btn--primary bib__cta"
              href={reg}
              target="_blank"
              rel="noopener noreferrer"
            >
              Inscribirse en Eventrid <span class="btn__arrow" aria-hidden="true">→</span>
            </a>
          )}
        </div>
      )
    }

    {
      event.categories.length > 0 && (
        <div class="enroll__cats">
          <div class="cats__head" data-reveal>
            <h2 class="cats__title">
              Categorías {distance && <span class="cats__hl">{distance}</span>}
            </h2>
            <p class="cats__kicker">Damas y Varones</p>
          </div>

          <div class="cats__grid">
            {event.categories.map((cat, i) => (
              <article class="cat" data-reveal data-delay={String(i + 1)}>
                <div class="cat__body">
                  <h3 class="cat__name">{cat.name}</h3>
                  <p class="cat__ages">{cat.ages}</p>
                </div>
              </article>
            ))}
          </div>

          {event.categoriesNote && <p class="cats__note" data-reveal>{event.categoriesNote}</p>}
        </div>
      )
    }
  </div>
</section>

<style>
  .enroll {
    position: relative;
    overflow: hidden;
    background: var(--fl-navy);
    color: var(--fl-cream);
  }
  .enroll__inner {
    position: relative;
    width: 100%;
    max-width: var(--fl-container);
    margin: 0 auto;
    padding: clamp(56px, 8vw, 104px) clamp(20px, 5vw, 56px);
  }

  /* --- DORSAL (ficha de inscripción) ------------------------------------- */
  .bib {
    position: relative;
    max-width: 760px;
    margin: 0 auto;
    /* Superficie un punto más clara que el lienzo: profundidad por tono, no
       por sombra (coherente con la filosofía de marca). */
    background: color-mix(in oklab, var(--fl-navy), white 5%);
    border: 1px solid rgba(246, 240, 228, 0.16);
  }

  .bib__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding: clamp(16px, 2.4vw, 22px) clamp(20px, 3vw, 34px);
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .bib__tag {
    margin: 0;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--fl-orange);
  }
  .bib__event {
    color: var(--fl-on-navy-muted);
  }

  /* Bandera de meta a cuadros: el motivo de marca, como banda fina. */
  .bib__flag {
    height: 12px;
    background-color: var(--fl-orange);
    background-image:
      linear-gradient(45deg, var(--fl-navy) 25%, transparent 25% 75%, var(--fl-navy) 75%),
      linear-gradient(45deg, var(--fl-navy) 25%, transparent 25% 75%, var(--fl-navy) 75%);
    background-size: 12px 12px;
    background-position: 0 0, 6px 6px;
  }

  .bib__body {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: clamp(28px, 5vw, 56px);
    padding: clamp(30px, 4.5vw, 52px) clamp(20px, 3vw, 34px);
  }
  @media (max-width: 560px) {
    .bib__body {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }

  /* Número de pecho, sentado sobre una grilla de cronómetro tenue. */
  .bib__num {
    position: relative;
  }
  .bib__num::before {
    content: '';
    position: absolute;
    inset: -10px -14px;
    background: repeating-linear-gradient(
      90deg,
      rgba(238, 83, 20, 0.14) 0 1px,
      transparent 1px 13px
    );
    -webkit-mask-image: linear-gradient(180deg, transparent, #000 28%, #000 72%, transparent);
    mask-image: linear-gradient(180deg, transparent, #000 28%, #000 72%, transparent);
    pointer-events: none;
  }
  .bib__eyebrow {
    position: relative;
    margin: 0 0 4px;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--fl-orange);
  }
  .amount {
    position: relative;
    margin: 0;
    font-family: 'Archivo Black', sans-serif;
    line-height: 0.82;
    letter-spacing: -0.05em;
    white-space: nowrap;
  }
  .amount__num {
    font-size: clamp(82px, 13vw, 148px);
  }
  .amount__cur {
    color: var(--fl-orange);
    font-size: clamp(28px, 4vw, 44px);
    letter-spacing: -0.02em;
    margin-left: 8px;
  }

  /* Filas etiqueta → valor: lee a comprobante, no a cartel. */
  .bib__rows {
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .row {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: clamp(12px, 2vw, 24px);
    padding: 16px 0;
    align-items: baseline;
  }
  .row + .row {
    border-top: 1px solid rgba(246, 240, 228, 0.1);
  }
  .row__k {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--fl-on-navy-muted);
  }
  .row__v {
    margin: 0;
    font-size: clamp(15px, 1.6vw, 17px);
    line-height: 1.35;
    color: var(--fl-cream);
  }
  .row__sub {
    color: var(--fl-on-navy-soft);
  }
  .incl {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .incl__item {
    position: relative;
    padding-left: 22px;
  }
  /* Marca naranja (motivo de marca) como viñeta. */
  .incl__item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.42em;
    width: 9px;
    height: 9px;
    background: var(--fl-orange);
  }

  .bib__cta {
    display: flex;
    justify-content: center;
    border-top: 1px solid rgba(246, 240, 228, 0.16);
  }

  /* --- Categorías (sub-bloque del mismo clúster) ------------------------- */
  .enroll__cats {
    margin-top: clamp(48px, 7vw, 88px);
  }
  .cats__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .cats__title {
    margin: 0;
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(30px, 4vw, 50px);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--fl-cream);
  }
  .cats__hl {
    color: var(--fl-orange);
  }
  .cats__kicker {
    margin: 0;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--fl-on-navy-muted);
  }
  .cats__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1px;
    background: rgba(246, 240, 228, 0.14);
    border-block: 1px solid rgba(246, 240, 228, 0.14);
  }
  .cat {
    background: var(--fl-navy);
    padding: 28px clamp(20px, 2.2vw, 28px) 30px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: background-color 220ms var(--ease-out);
  }
  .cat__name {
    margin: 0;
    font-family: 'Archivo Black', sans-serif;
    font-size: 26px;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--fl-cream);
  }
  .cat__ages {
    margin: 6px 0 0;
    font-size: 16px;
    color: var(--fl-on-navy-soft);
  }
  @media (hover: hover) {
    .cat:hover {
      background: rgba(246, 240, 228, 0.05);
    }
  }
  .cats__note {
    margin: 18px 0 0;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.5px;
    color: var(--fl-on-navy-muted);
  }

  /* --- CTA --------------------------------------------------------------- */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 17px 30px;
    text-decoration: none;
    transition:
      transform 180ms var(--ease-out),
      background-color 180ms var(--ease-out);
  }
  .btn--primary {
    background: var(--fl-orange-strong);
    color: #fff;
  }
  .btn__arrow {
    transition: transform 180ms var(--ease-out);
  }
  @media (hover: hover) {
    .btn--primary:hover {
      background: var(--fl-orange-hover);
    }
    .btn:hover .btn__arrow {
      transform: translateX(4px);
    }
  }
  .btn:active {
    transform: scale(0.97);
  }
</style>
