---
import type { EventData } from '../format';
import { heroDate, placeLine } from '../format';
import { Image } from 'astro:assets';
import Countdown from './Countdown.astro';

interface Props {
  event: EventData;
}
const { event } = Astro.props;

const reg = event.registrationUrl;
const distance = event.distances[0];
const eyebrow = `${heroDate(event.date)} — ${placeLine(event)}`;
const altitude = event.altitudeM ? new Intl.NumberFormat('es-BO').format(event.altitudeM) : null;
---

<section id="carrera" class="hero">
  {
    event.heroImage && (
      <Image
        class="hero__photo"
        src={event.heroImage}
        alt={`Participantes de ${event.title} corriendo cuesta arriba por el centro de ${placeLine(event)}, de espaldas, al amanecer`}
        widths={[768, 1200, 1600]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
    )
  }
  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="hero__inner">
    <div class="hero__copy">
      <p class="eyebrow" data-reveal>{eyebrow}</p>
      <h1 class="hero__title" data-reveal data-delay="1">{event.tagline ?? event.title}</h1>

      <div class="hero__stats" data-reveal data-delay="2">
        {distance && <span class="hero__distance">{distance}</span>}
        {
          altitude && (
            <div class="hero__alt">
              <span class="hero__alt-num">
                {altitude}
                <span class="hero__alt-unit">m s. n. m.</span>
              </span>
            </div>
          )
        }
      </div>

      {event.description && <p class="hero__desc" data-reveal data-delay="3">{event.description}</p>}

      <div class="hero__actions" data-reveal data-delay="3">
        {
          reg && (
            <a class="btn btn--primary" href={reg} target="_blank" rel="noopener noreferrer">
              Inscribirse ahora <span class="btn__arrow" aria-hidden="true">→</span>
            </a>
          )
        }
        <a class="btn btn--ghost" href="#recorrido">Ver recorrido</a>
      </div>
    </div>

    {event.instagram && <span class="hero__handle" aria-hidden="true">{event.instagram.toUpperCase()}</span>}
  </div>

  {/* El contador cierra el hero: la cuenta regresiva ES la línea de meta. */}
  <Countdown {event} />
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: calc(100vh - var(--fl-header-h, 74px));
    min-height: calc(100dvh - var(--fl-header-h, 74px));
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: var(--fl-navy);
  }
  .hero__photo {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 38%;
  }
  /* Scrim para legibilidad del copy (abajo-izquierda). */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(
        to top,
        var(--fl-navy) 2%,
        rgba(14, 28, 48, 0.82) 22%,
        rgba(14, 28, 48, 0.32) 52%,
        rgba(14, 28, 48, 0.05) 80%
      ),
      linear-gradient(
        to right,
        rgba(14, 28, 48, 0.85) 0%,
        rgba(14, 28, 48, 0.34) 44%,
        transparent 72%
      );
  }

  .hero__inner {
    position: relative;
    width: 100%;
    max-width: var(--fl-container);
    margin: 0 auto;
    padding: clamp(40px, 7vw, 96px) clamp(20px, 5vw, 56px) clamp(28px, 3.5vw, 48px);
  }
  .hero__copy {
    max-width: 760px;
  }

  .eyebrow {
    margin: 0;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--fl-orange);
  }
  .hero__title {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(40px, 7.4vw, 88px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    margin: 16px 0 0;
    text-transform: uppercase;
    white-space: pre-line; /* respeta los saltos de línea del tagline */
    color: var(--fl-cream);
  }

  /* Fila de datos: distancia + altitud sobreimpresos sobre la foto. */
  .hero__stats {
    display: flex;
    align-items: flex-end;
    gap: clamp(22px, 4vw, 44px);
    margin-top: 24px;
    flex-wrap: wrap;
  }
  .hero__distance {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(40px, 6vw, 64px);
    line-height: 0.9;
    color: var(--fl-orange);
  }
  .hero__alt {
    display: flex;
    align-items: flex-end;
    padding-bottom: 4px;
    border-left: 1px solid rgba(246, 240, 228, 0.22);
    padding-left: clamp(18px, 3vw, 28px);
  }
  .hero__alt-num {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(26px, 3.4vw, 38px);
    line-height: 0.9;
    color: var(--fl-cream);
  }
  .hero__alt-unit {
    font-size: 0.5em;
    color: var(--fl-orange);
    margin-left: 3px;
  }

  .hero__desc {
    margin: 22px 0 0;
    max-width: 460px;
    font-size: 16px;
    line-height: 1.55;
    color: #c9d4e1;
  }
  .hero__actions {
    display: flex;
    gap: 14px;
    margin-top: 28px;
    flex-wrap: wrap;
  }
  .hero__handle {
    position: absolute;
    top: clamp(20px, 4vw, 36px);
    right: clamp(20px, 5vw, 56px);
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: rgba(246, 240, 228, 0.7);
  }

  /* Botones */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 16px 26px;
    text-decoration: none;
    transition:
      transform 180ms var(--ease-out),
      background-color 180ms var(--ease-out),
      border-color 180ms var(--ease-out);
  }
  .btn--primary {
    background: var(--fl-orange-strong);
    color: #fff;
  }
  .btn--ghost {
    border: 1px solid rgba(246, 240, 228, 0.45);
    color: var(--fl-cream);
    background: rgba(14, 28, 48, 0.25);
    backdrop-filter: blur(2px);
  }
  .btn__arrow {
    transition: transform 180ms var(--ease-out);
  }
  @media (hover: hover) {
    .btn--primary:hover {
      transform: translateY(-2px);
      background: var(--fl-orange-hover);
    }
    .btn--ghost:hover {
      transform: translateY(-2px);
      border-color: var(--fl-cream);
    }
    .btn:hover .btn__arrow {
      transform: translateX(4px);
    }
  }
  .btn:active {
    transform: scale(0.97);
  }

  /* El contador, último hijo, queda como banda al pie del hero. */
  .hero > :global(.cd) {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 640px) {
    .hero__handle {
      display: none;
    }
    /* El recorrido detallado vive en su sección; en móvil el hero va liviano
       para ocupar exactamente una pantalla sin que asome la siguiente. */
    .hero__desc {
      display: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .btn,
    .btn__arrow {
      transition: none;
    }
  }
</style>
