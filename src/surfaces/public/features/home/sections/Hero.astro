---
import type { EventData } from '../format';
import { heroDate, placeLine } from '../format';

interface Props {
  event: EventData;
}
const { event } = Astro.props;

const reg = event.registrationUrl;
const distance = event.distances[0];
const eyebrow = `${heroDate(event.date)} — ${placeLine(event)}`;
const altitude = event.altitudeM ? new Intl.NumberFormat('es-BO').format(event.altitudeM) : null;

const logistics = [
  event.gatheringTime && `Concentración ${event.gatheringTime}`,
  event.startTime && `Partida ${event.startTime}`,
  event.price && `Costo ${event.price.currency} ${event.price.amount}`,
]
  .filter(Boolean)
  .join(' · ');
---

<section id="carrera" class="hero">
  <div class="hero__hatch" aria-hidden="true"></div>
  <div class="hero__inner">
    <div class="hero__copy">
      <p class="eyebrow" data-reveal>{eyebrow}</p>
      <h1 class="hero__title" data-reveal data-delay="1">{event.tagline ?? event.title}</h1>

      <div class="hero__lead" data-reveal data-delay="2">
        {distance && <span class="hero__distance">{distance}</span>}
        {event.description && <p class="hero__desc">{event.description}</p>}
      </div>

      <div class="hero__actions" data-reveal data-delay="3">
        {
          reg && (
            <a class="btn btn--primary" href={reg} target="_blank" rel="noopener noreferrer">
              Inscribirse ahora <span class="btn__arrow" aria-hidden="true">→</span>
            </a>
          )
        }
        <a class="btn btn--ghost" href="#recorrido">Ver recorrido</a>
      </div>

      {logistics && <p class="hero__logistics" data-reveal data-delay="4">{logistics}</p>}
    </div>

    <div class="hero__media" data-reveal data-delay="2">
      <div class="alt">
        {/* Foto opcional como capa de fondo (duotono) cuando exista heroImage */}
        {
          event.heroImage && (
            <img
              class="alt__photo"
              src={event.heroImage}
              alt={`Corredores en ${placeLine(event)}`}
              loading="eager"
            />
          )
        }

        {/* Contornos topográficos: la altitud hecha gráfica */}
        <svg class="alt__topo" viewBox="0 0 400 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
          <g transform="translate(205 250)" fill="none" stroke-width="1.5">
            <path d="M -120,-40 C -90,-110 60,-120 110,-60 C 150,-10 120,90 40,110 C -50,130 -150,60 -120,-40 Z" transform="scale(1.5)" stroke="rgba(246,240,228,0.06)"></path>
            <path d="M -120,-40 C -90,-110 60,-120 110,-60 C 150,-10 120,90 40,110 C -50,130 -150,60 -120,-40 Z" transform="scale(1.18)" stroke="rgba(238,83,20,0.16)"></path>
            <path d="M -120,-40 C -90,-110 60,-120 110,-60 C 150,-10 120,90 40,110 C -50,130 -150,60 -120,-40 Z" transform="scale(0.9)" stroke="rgba(246,240,228,0.1)"></path>
            <path d="M -120,-40 C -90,-110 60,-120 110,-60 C 150,-10 120,90 40,110 C -50,130 -150,60 -120,-40 Z" transform="scale(0.62)" stroke="rgba(238,83,20,0.5)"></path>
            <path d="M -120,-40 C -90,-110 60,-120 110,-60 C 150,-10 120,90 40,110 C -50,130 -150,60 -120,-40 Z" transform="scale(0.34)" stroke="rgba(246,240,228,0.16)"></path>
            <circle r="4" fill="var(--fl-orange)" stroke="none"></circle>
          </g>
        </svg>

        {/* Contenido: la historia de la altitud */}
        {
          altitude && (
            <div class="alt__content">
              <span class="alt__label">Altitud</span>
              <div class="alt__num">
                {altitude}
                <span class="alt__unit">m</span>
              </div>
              {event.altitudeNote && <p class="alt__note">{event.altitudeNote}</p>}
            </div>
          )
        }

        {event.instagram && <span class="alt__handle">{event.instagram.toUpperCase()}</span>}
        <div class="alt__flag" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(120% 90% at 80% 0%, rgba(238, 83, 20, 0.08) 0%, transparent 55%),
      var(--fl-navy);
  }
  .hero__hatch {
    position: absolute;
    top: 0;
    right: 0;
    width: 46%;
    height: 100%;
    background: repeating-linear-gradient(
      135deg,
      rgba(238, 83, 20, 0.05) 0 2px,
      transparent 2px 22px
    );
    pointer-events: none;
  }
  .hero__inner {
    position: relative;
    max-width: var(--fl-container);
    margin: 0 auto;
    padding: clamp(44px, 7vw, 92px) clamp(20px, 5vw, 56px);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }
  .eyebrow {
    margin: 0;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--fl-orange);
  }
  .hero__title {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(42px, 6.6vw, 94px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    margin: 20px 0 0;
    text-transform: uppercase;
    text-wrap: balance;
  }
  .hero__lead {
    display: flex;
    align-items: baseline;
    gap: 18px;
    margin-top: 22px;
    flex-wrap: wrap;
  }
  .hero__distance {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(36px, 5vw, 60px);
    color: var(--fl-orange);
    line-height: 1;
  }
  .hero__desc {
    margin: 0;
    max-width: 360px;
    font-size: 16px;
    line-height: 1.5;
    color: #b9c6d6;
  }
  .hero__actions {
    display: flex;
    gap: 14px;
    margin-top: 30px;
    flex-wrap: wrap;
  }
  .hero__logistics {
    margin: 26px 0 0;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 1px;
    color: #8295aa;
    text-transform: uppercase;
  }

  /* Botones */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 16px 26px;
    text-decoration: none;
    transition:
      transform 180ms var(--ease-out),
      background-color 180ms var(--ease-out);
  }
  .btn--primary {
    background: var(--fl-orange);
    color: #fff;
  }
  .btn--ghost {
    border: 1px solid rgba(246, 240, 228, 0.35);
    color: var(--fl-cream);
  }
  .btn__arrow {
    transition: transform 180ms var(--ease-out);
  }
  @media (hover: hover) {
    .btn--primary:hover {
      transform: translateY(-2px);
      background: #ff5e1d;
    }
    .btn--ghost:hover {
      transform: translateY(-2px);
      border-color: var(--fl-cream);
    }
    .btn:hover .btn__arrow {
      transform: translateX(4px);
    }
  }
  .btn:active {
    transform: scale(0.97);
  }

  /* Panel de altitud (graphic-led) */
  .hero__media {
    position: relative;
  }
  .alt {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: linear-gradient(160deg, #12243c 0%, #0b1727 100%);
    border: 1px solid rgba(246, 240, 228, 0.12);
  }
  .alt__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.05) brightness(0.7) sepia(0.3) hue-rotate(-15deg);
    opacity: 0.5;
  }
  .alt__topo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .alt__content {
    position: absolute;
    left: clamp(20px, 4vw, 32px);
    bottom: clamp(20px, 4vw, 34px);
  }
  .alt__label {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--fl-orange);
  }
  .alt__num {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(56px, 9vw, 96px);
    line-height: 0.86;
    letter-spacing: -0.03em;
    margin-top: 6px;
    color: var(--fl-cream);
  }
  .alt__unit {
    font-size: 0.4em;
    color: var(--fl-orange);
    margin-left: 4px;
  }
  .alt__note {
    margin: 8px 0 0;
    max-width: 220px;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 1px;
    line-height: 1.4;
    text-transform: uppercase;
    color: #aebbcb;
  }
  .alt__handle {
    position: absolute;
    right: 16px;
    top: 16px;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: rgba(246, 240, 228, 0.6);
    pointer-events: none;
  }
  .alt__flag {
    position: absolute;
    right: -6px;
    bottom: -6px;
    width: 130px;
    height: 18px;
    background: repeating-linear-gradient(135deg, var(--fl-orange) 0 12px, var(--fl-navy) 12px 24px);
  }
</style>
