---
import type { EventData } from '../format';
import { placeLine, dayMonth } from '../format';
import { Image } from 'astro:assets';
import logo from '../../../../../assets/images/logo.png';

interface Props {
  event: EventData;
}
const { event } = Astro.props;
const reg = event.registrationUrl;
const year = new Date().getFullYear();
const eventYear = event.date.getUTCFullYear();
const place = placeLine(event);
const organizer = event.organizer ?? 'Finish Line Sporting Events';
const copyright = `© ${year} ${organizer}`;
const whenLine = `${dayMonth(event.date)} ${eventYear} · ${event.city ?? place}`;

// Dos intenciones distintas, no se mezclan:
//  · WhatsApp = CONTACTO directo (responde al "¿Tienes dudas?"), con etiqueta.
//  · Instagram/Facebook/TikTok/YouTube = SEGUIR, glifos reconocibles → solo ícono.
// Data-driven: cada canal aparece solo si el evento lo define.
let whatsapp: { href: string; detail: string } | null = null;
if (event.whatsapp) {
  const digits = event.whatsapp.replace(/\D/g, '');
  const text = encodeURIComponent(`Hola, tengo una consulta sobre ${event.title}.`);
  whatsapp = { href: `https://wa.me/${digits}?text=${text}`, detail: event.whatsapp };
}

type SocialIcon = 'instagram' | 'facebook' | 'tiktok' | 'youtube';
type Social = { label: string; href: string; icon: SocialIcon };
const socials: Social[] = [];
if (event.instagramUrl) socials.push({ label: 'Instagram', href: event.instagramUrl, icon: 'instagram' });
if (event.facebookUrl) socials.push({ label: 'Facebook', href: event.facebookUrl, icon: 'facebook' });
if (event.tiktokUrl) socials.push({ label: 'TikTok', href: event.tiktokUrl, icon: 'tiktok' });
if (event.youtubeUrl) socials.push({ label: 'YouTube', href: event.youtubeUrl, icon: 'youtube' });

const hasReach = whatsapp !== null || socials.length > 0;

// Glifos de marca (simple-icons, viewBox 24), pintados con currentColor.
const icons: Record<'whatsapp' | SocialIcon, string> = {
  whatsapp:
    'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z',
  instagram:
    'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069M12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24s3.668-.014 4.948-.072c4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948s-.014-3.667-.072-4.947c-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0m0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324M12 16a4 4 0 110-8 4 4 0 010 8m6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881',
  facebook:
    'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073',
  tiktok:
    'M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z',
  youtube:
    'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z',
};
---

<footer class="ft">
  {/* La línea de meta: cruzás la bandera al llegar al final del scroll. */}
  <div class="ft__finish" aria-hidden="true"></div>

  <div class="ft__inner">
    {/* Clímax de cierre */}
    <div class="ft__close">
      <h2 class="ft__big" data-reveal>Nos vemos<br />en la meta</h2>
      <div class="ft__closemeta" data-reveal data-delay="1">
        <span class="ft__when">{whenLine}</span>
        {
          reg && (
            <a class="btn btn--primary" href={reg} target="_blank" rel="noopener noreferrer">
              Inscribirse en Eventrid <span class="btn__arrow" aria-hidden="true">→</span>
            </a>
          )
        }
      </div>
    </div>

    {/* Contacto + redes: resolver dudas (WhatsApp) y seguir (redes) */}
    {
      hasReach && (
        <div class="ft__connect" data-reveal data-delay="2">
          <div class="ft__connectcopy">
            <p class="ft__connecth">¿Tienes dudas?</p>
            <p class="ft__connectsub">Escríbenos y te respondemos antes de la largada.</p>
          </div>

          <div class="ft__reach">
            {whatsapp && (
              <a
                class="wa"
                href={whatsapp.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`WhatsApp — ${whatsapp.detail}`}
              >
                <svg class="wa__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d={icons.whatsapp} />
                </svg>
                <span class="wa__text">
                  <span class="wa__label">WhatsApp</span>
                  <span class="wa__detail">{whatsapp.detail}</span>
                </span>
              </a>
            )}

            {socials.length > 0 && (
              <div class="ft__follow">
                <span class="ft__followlabel">Síguenos</span>
                <ul class="ft__socials">
                  {socials.map((s) => (
                    <li>
                      <a
                        class="soc"
                        href={s.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={s.label}
                      >
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d={icons[s.icon]} />
                        </svg>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      )
    }

    {/* Créditos */}
    <div class="ft__bar">
      <div class="ft__org">
        <span class="ft__orglabel">Organiza</span>
        <span class="ft__plaque">
          <Image class="ft__logo" src={logo} alt={organizer} width={420} height={380} loading="lazy" />
        </span>
      </div>
      <div class="ft__meta">
        {place && <span class="ft__social">{place}</span>}
        <span class="ft__legal">{copyright}</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .ft {
    background: var(--fl-navy);
    color: var(--fl-cream);
  }
  /* Bandera de meta a cuadros, full-bleed, en el borde superior del footer. */
  .ft__finish {
    height: 20px;
    background-color: var(--fl-orange);
    background-image:
      linear-gradient(45deg, var(--fl-navy) 25%, transparent 25% 75%, var(--fl-navy) 75%),
      linear-gradient(45deg, var(--fl-navy) 25%, transparent 25% 75%, var(--fl-navy) 75%);
    background-size: 20px 20px;
    background-position:
      0 0,
      10px 10px;
  }
  .ft__inner {
    max-width: var(--fl-container);
    margin: 0 auto;
    padding: clamp(48px, 7vw, 84px) clamp(20px, 5vw, 56px) clamp(34px, 4vw, 48px);
  }

  /* --- Clímax ------------------------------------------------------------ */
  .ft__close {
    padding-bottom: clamp(36px, 5vw, 56px);
    border-bottom: 1px solid rgba(246, 240, 228, 0.12);
  }
  .ft__big {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(46px, 9vw, 112px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    margin: 0;
    text-wrap: balance;
  }
  .ft__closemeta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: clamp(18px, 3vw, 36px);
    margin-top: clamp(24px, 3.5vw, 40px);
  }
  .ft__when {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--fl-orange);
  }

  /* --- CTA --------------------------------------------------------------- */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 17px 30px;
    text-decoration: none;
    white-space: nowrap;
    transition:
      transform 180ms var(--ease-out),
      background-color 180ms var(--ease-out);
  }
  .btn--primary {
    background: var(--fl-orange-strong);
    color: #fff;
  }
  .btn__arrow {
    transition: transform 180ms var(--ease-out);
  }
  @media (hover: hover) {
    .btn--primary:hover {
      transform: translateY(-2px);
      background: var(--fl-orange-hover);
    }
    .btn:hover .btn__arrow {
      transform: translateX(4px);
    }
  }
  .btn:active {
    transform: scale(0.97);
  }

  /* --- Contacto / redes -------------------------------------------------- */
  .ft__connect {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: clamp(22px, 4vw, 48px);
    padding: clamp(30px, 4.5vw, 52px) 0;
    border-bottom: 1px solid rgba(246, 240, 228, 0.12);
  }
  .ft__connectcopy {
    min-width: 0;
  }
  .ft__connecth {
    margin: 0;
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(24px, 3.4vw, 38px);
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--fl-cream);
  }
  .ft__connectsub {
    margin: 12px 0 0;
    font-size: 15px;
    line-height: 1.45;
    color: var(--fl-on-navy-soft);
    max-width: 38ch;
    text-wrap: pretty;
  }
  /* Bloque de alcance: contacto (WhatsApp) arriba, seguir (redes) abajo. */
  .ft__reach {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: clamp(18px, 2.5vw, 24px);
  }

  /* WhatsApp = contacto directo, CON etiqueta. Chip cuadrado (sin radius). */
  .wa {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-height: 48px;
    padding: 10px 20px 10px 16px;
    border: 1px solid rgba(246, 240, 228, 0.18);
    color: var(--fl-cream);
    text-decoration: none;
    transition:
      border-color 160ms var(--ease-out),
      background-color 160ms var(--ease-out),
      transform 160ms var(--ease-out);
  }
  .wa__icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    color: var(--fl-orange);
  }
  .wa__text {
    display: flex;
    flex-direction: column;
    gap: 1px;
    line-height: 1.15;
    white-space: nowrap;
  }
  .wa__label {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .wa__detail {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.5px;
    color: var(--fl-on-navy-muted);
  }
  @media (hover: hover) {
    .wa:hover {
      border-color: var(--fl-orange);
      background: rgba(238, 83, 20, 0.1);
      transform: translateY(-2px);
    }
  }
  .wa:active {
    transform: scale(0.98);
  }
  .wa:focus-visible {
    outline: 2px solid var(--fl-orange);
    outline-offset: 2px;
  }

  /* Seguir = glifos reconocibles, SOLO ícono (cuadros de 44px). */
  .ft__follow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
  }
  .ft__followlabel {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--fl-on-navy-muted);
  }
  .ft__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .soc {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(246, 240, 228, 0.18);
    color: var(--fl-cream);
    transition:
      border-color 160ms var(--ease-out),
      background-color 160ms var(--ease-out),
      color 160ms var(--ease-out),
      transform 160ms var(--ease-out);
  }
  .soc svg {
    width: 20px;
    height: 20px;
  }
  @media (hover: hover) {
    .soc:hover {
      border-color: var(--fl-orange);
      background: rgba(238, 83, 20, 0.1);
      color: var(--fl-orange);
      transform: translateY(-2px);
    }
  }
  .soc:active {
    transform: scale(0.95);
  }
  .soc:focus-visible {
    outline: 2px solid var(--fl-orange);
    outline-offset: 2px;
  }

  /* --- Barra inferior: organizador + meta -------------------------------- */
  .ft__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(20px, 4vw, 40px);
    flex-wrap: wrap;
    padding-top: clamp(28px, 4vw, 40px);
  }
  .ft__org {
    display: flex;
    align-items: center;
    gap: clamp(14px, 2vw, 20px);
  }
  .ft__orglabel {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--fl-on-navy-muted);
  }
  /* Placa clara: el logo tiene partes navy; sobre ella se mantienen legibles. */
  .ft__plaque {
    display: inline-flex;
    background: var(--fl-cream);
    padding: clamp(10px, 1.5vw, 14px) clamp(14px, 2vw, 20px);
  }
  .ft__logo {
    height: clamp(48px, 6vw, 68px);
    width: auto;
    display: block;
  }
  .ft__meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-align: right;
  }
  .ft__social {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--fl-on-navy-muted);
  }
  .ft__legal {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #5d6f86;
  }

  @media (max-width: 520px) {
    .ft__meta {
      text-align: left;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .btn,
    .wa,
    .soc {
      transition: none;
    }
  }
</style>
