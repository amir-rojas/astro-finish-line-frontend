---
import type { EventData } from '../format';
import { placeLine } from '../format';

interface Props {
  event: EventData;
}
const { event } = Astro.props;
const reg = event.registrationUrl;
const year = new Date().getFullYear();
const place = placeLine(event);
const social = [event.instagram, place].filter(Boolean).join(' · ');
const copyright = `© ${year} ${event.organizer ?? 'Finish Line Sporting Events'}`;
---

<footer id="app" class="ft">
  <div class="ft__inner">
    <div class="ft__app">
      <div class="ft__appcopy" data-reveal>
        <p class="eyebrow">// Próximamente</p>
        <h2 class="ft__title">La app de Finish Line</h2>
        <p class="ft__desc">
          Inscríbete, revisa tus resultados y vive cada carrera desde tu teléfono.
          Estamos construyéndola. Por ahora, la inscripción se realiza en Eventrid.
        </p>
      </div>
      {
        reg && (
          <a
            class="btn btn--primary"
            href={reg}
            target="_blank"
            rel="noopener noreferrer"
            data-reveal
            data-delay="1"
          >
            Inscribirse en Eventrid <span class="btn__arrow" aria-hidden="true">→</span>
          </a>
        )
      }
    </div>

    <div class="ft__bar">
      <div class="brand">
        <span class="brand__mark" aria-hidden="true"></span>
        <span class="brand__word">FINISH LINE</span>
      </div>
      {social && <div class="ft__social">{social}</div>}
      <div class="ft__legal">{copyright}</div>
    </div>
  </div>
</footer>

<style>
  .ft {
    background: var(--fl-navy);
    color: var(--fl-cream);
  }
  .ft__inner {
    max-width: var(--fl-container);
    margin: 0 auto;
    padding: clamp(48px, 7vw, 84px) clamp(20px, 5vw, 56px) clamp(34px, 4vw, 48px);
  }
  .ft__app {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    align-items: center;
    padding-bottom: clamp(36px, 5vw, 56px);
    border-bottom: 1px solid rgba(246, 240, 228, 0.12);
  }
  .eyebrow {
    margin: 0;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--fl-orange);
  }
  .ft__title {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(30px, 3.6vw, 46px);
    margin: 12px 0 0;
    text-transform: uppercase;
    letter-spacing: -1px;
    line-height: 0.98;
  }
  .ft__desc {
    font-size: 16px;
    line-height: 1.5;
    color: #b9c6d6;
    margin: 14px 0 0;
    max-width: 440px;
  }
  .btn {
    justify-self: start;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 17px 30px;
    text-decoration: none;
    white-space: nowrap;
    transition:
      transform 180ms var(--ease-out),
      background-color 180ms var(--ease-out);
  }
  .btn--primary {
    background: var(--fl-orange);
    color: #fff;
  }
  .btn__arrow {
    transition: transform 180ms var(--ease-out);
  }
  @media (hover: hover) {
    .btn--primary:hover {
      transform: translateY(-2px);
      background: #ff5e1d;
    }
    .btn:hover .btn__arrow {
      transform: translateX(4px);
    }
  }
  .btn:active {
    transform: scale(0.97);
  }

  .ft__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    padding-top: 30px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 11px;
  }
  .brand__mark {
    width: 12px;
    height: 12px;
    background: var(--fl-orange);
  }
  .brand__word {
    font-family: 'Archivo Black', sans-serif;
    font-size: 20px;
    letter-spacing: 1px;
  }
  .ft__social {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #8295aa;
  }
  .ft__legal {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #5d6f86;
  }

  @media (min-width: 720px) {
    .ft__app .btn {
      justify-self: end;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .btn {
      transition: none;
    }
  }
</style>
