---
import type { EventData } from '../format';
import { dayMonth } from '../format';
// Trazado real del recorrido (fuente de verdad: GeoJSON generado del GPX con
// scripts/gpx-to-geojson.mjs). Se proyecta a un perfil de elevación en SVG.
import routeRaw from '../data/lapaz-route.geojson?raw';

interface Props {
  event: EventData;
}
const { event } = Astro.props;

const distance = event.distances[0] ?? '';
const title = event.courseTitle ?? `${distance} por el centro de ${event.city ?? ''}`.trim();
const desc = event.courseDescription ?? `Salida y meta en ${event.location}.`;

const deadlineBadge = event.registrationDeadline
  ? `Cierre ${dayMonth(event.registrationDeadline)}${
      event.registrationNote ? ` · ${event.registrationNote}` : ''
    }`
  : null;

// --- Perfil de elevación real -------------------------------------------
interface RouteData {
  properties: {
    totalKm: number;
    elevation: { minM: number; maxM: number; gainM: number };
    profile: [number, number][]; // [km, ele]
  };
}
const route = JSON.parse(routeRaw) as RouteData;
const { profile, totalKm, elevation } = route.properties;

const nf = new Intl.NumberFormat('es-BO');
const eMin = elevation.minM;
const eMax = elevation.maxM;

// Geometría del gráfico (viewBox 560×360).
const W = 560;
const PAD_L = 44;
const PAD_R = 40;
const TOP = 64; // techo del trazo (deja aire para la etiqueta de cima)
const BOTTOM = 290; // piso del trazo
const BASE = 300; // línea base / eje de km

const px = (km: number) => PAD_L + (km / totalKm) * (W - PAD_L - PAD_R);
const py = (e: number) => BOTTOM - ((e - eMin) / (eMax - eMin)) * (BOTTOM - TOP);

const line = profile
  .map(([km, e], i) => `${i === 0 ? 'M' : 'L'}${px(km).toFixed(1)},${py(e).toFixed(1)}`)
  .join(' ');
const area = `M${px(0).toFixed(1)},${BASE} ${profile
  .map(([km, e]) => `L${px(km).toFixed(1)},${py(e).toFixed(1)}`)
  .join(' ')} L${px(totalKm).toFixed(1)},${BASE} Z`;

const kmMarks = [0, 2, 4, 6, 8, 10].filter((k) => k <= Math.ceil(totalKm));

const start = profile[0];
const end = profile[profile.length - 1];
// Punto más bajo (el fondo del valle): el momento característico del trazado.
const low = profile.reduce((a, b) => (b[1] < a[1] ? b : a), profile[0]);

const ariaLabel =
  `Perfil de elevación real del recorrido de ${distance}: ${totalKm.toFixed(1)} km, ` +
  `entre ${nf.format(Math.round(eMin))} y ${nf.format(Math.round(eMax))} metros, ` +
  `desnivel positivo de ${elevation.gainM} metros.`;
---

<section id="recorrido" class="course">
  <div class="course__inner">
    <div class="course__copy">
      <p class="eyebrow" data-reveal>// El recorrido</p>
      <h2 class="course__title" data-reveal data-delay="1">{title}</h2>
      <p class="course__desc" data-reveal data-delay="2">{desc}</p>
      <dl class="course__stats" data-reveal data-delay="3">
        <div class="stat">
          <dt class="stat__k">Distancia</dt>
          <dd class="stat__v">{totalKm.toFixed(1)} <span class="stat__u">km</span></dd>
        </div>
        <div class="stat">
          <dt class="stat__k">Altitud</dt>
          <dd class="stat__v">
            {nf.format(Math.round(eMin))}–{nf.format(Math.round(eMax))} <span class="stat__u">m</span>
          </dd>
        </div>
        <div class="stat">
          <dt class="stat__k">Desnivel</dt>
          <dd class="stat__v">+{elevation.gainM} <span class="stat__u">m</span></dd>
        </div>
      </dl>
      {deadlineBadge && <p class="course__badge" data-reveal data-delay="3">{deadlineBadge}</p>}
    </div>

    <figure class="profile" data-reveal data-delay="2">
      <svg viewBox="0 0 560 360" role="img" aria-label={ariaLabel}>
        <defs>
          <linearGradient id="prof-fill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="rgba(238,83,20,0.26)"></stop>
            <stop offset="100%" stop-color="rgba(238,83,20,0)"></stop>
          </linearGradient>
        </defs>

        {/* baseline + km ticks */}
        <line x1={PAD_L} y1={BASE} x2={W - PAD_R} y2={BASE} stroke="rgba(20,35,58,0.25)" stroke-width="1"></line>
        {
          kmMarks.map((km) => (
            <g>
              <line
                x1={px(km)}
                y1={BASE}
                x2={px(km)}
                y2={BASE + 6}
                stroke="rgba(20,35,58,0.35)"
                stroke-width="1"
              />
              <text x={px(km)} y={BASE + 24} class="profile__tick">
                {km === 10 ? '10 KM' : km}
              </text>
            </g>
          ))
        }

        {/* área + línea de elevación real */}
        <path d={area} fill="url(#prof-fill)"></path>
        <path
          d={line}
          fill="none"
          stroke="#ee5314"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"></path>

        {/* punto más bajo (fondo del valle) */}
        <line
          x1={px(low[0])}
          y1={py(low[1])}
          x2={px(low[0])}
          y2={BASE}
          stroke="rgba(20,35,58,0.18)"
          stroke-width="1"
          stroke-dasharray="2 4"></line>
        <circle cx={px(low[0])} cy={py(low[1])} r="3.5" fill="var(--fl-ink)"></circle>
        <text x={px(low[0])} y={py(low[1]) - 10} class="profile__low">
          {nf.format(Math.round(low[1]))} m
        </text>

        {/* salida / meta */}
        <circle cx={px(start[0])} cy={py(start[1])} r="6" fill="#ee5314"></circle>
        <circle cx={px(end[0])} cy={py(end[1])} r="6" fill="var(--fl-ink)"></circle>
        <text x={px(start[0])} y={py(start[1]) - 14} class="profile__pt">Salida</text>
        <text x={px(end[0])} y={py(end[1]) - 14} class="profile__pt profile__pt--end">Meta</text>
      </svg>
      <figcaption class="profile__cap">Perfil de elevación · datos GPS del circuito</figcaption>
    </figure>
  </div>
</section>

<style>
  .course {
    background: var(--fl-cream-2);
    color: var(--fl-ink);
  }
  .course__inner {
    max-width: var(--fl-container);
    margin: 0 auto;
    padding: clamp(48px, 6vw, 88px) clamp(20px, 5vw, 56px);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: clamp(28px, 4vw, 56px);
    align-items: center;
  }
  .eyebrow {
    margin: 0;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #9a8f78;
  }
  .course__title {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(32px, 4.2vw, 52px);
    margin: 14px 0 0;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.96;
    text-wrap: balance;
  }
  .course__desc {
    font-size: 16px;
    line-height: 1.55;
    color: #5a5346;
    margin: 16px 0 0;
    max-width: 420px;
  }

  /* Estadísticas reales del trazado. */
  .course__stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(20px, 4vw, 40px);
    margin: 26px 0 0;
  }
  .stat {
    margin: 0;
  }
  .stat__k {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #9a8f78;
  }
  .stat__v {
    margin: 6px 0 0;
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(22px, 2.6vw, 30px);
    letter-spacing: -0.02em;
    color: var(--fl-ink);
  }
  .stat__u {
    font-size: 0.5em;
    color: var(--fl-orange);
    margin-left: 2px;
  }

  .course__badge {
    display: inline-block;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    background: var(--fl-ink);
    color: var(--fl-cream);
    padding: 11px 18px;
    margin: 24px 0 0;
  }

  .profile {
    margin: 0;
    background: var(--fl-cream-3);
    border: 1px solid rgba(20, 35, 58, 0.1);
    padding: 18px 18px 10px;
  }
  .profile svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .profile__tick {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    fill: #6b6456;
    text-anchor: middle;
  }
  .profile__pt {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    fill: var(--fl-orange);
    text-anchor: start;
  }
  .profile__pt--end {
    fill: var(--fl-ink);
    text-anchor: end;
  }
  .profile__low {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.5px;
    fill: #6b6456;
    text-anchor: middle;
  }
  .profile__cap {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #9a8f78;
    margin-top: 6px;
  }
</style>
