---
import type { EventData } from '../format';
import { dayMonth } from '../format';
import { Image } from 'astro:assets';
// Mapa oficial del recorrido (provisto por el organizador). Reemplaza la
// silueta/perfil dibujados en SVG: el mapa ya trae calles, puntos de partida
// y meta y la marca del evento.
import routeMap from '../../../../../assets/images/img-route.jpeg';
// Datos reales del recorrido (GeoJSON generado del GPX) para las cifras de
// distancia / altitud / desnivel del encabezado.
import routeRaw from '../data/lapaz-route.geojson?raw';

interface Props {
  event: EventData;
}
const { event } = Astro.props;

const distance = event.distances[0] ?? '';
const title = event.courseTitle ?? `${distance} por el centro de ${event.city ?? ''}`.trim();

// Logística que el mapa no detalla legible: concentración, partida y meta.
const partida = [event.startTime, event.location].filter(Boolean).join(' · ');
const meta = event.finishLocation;

const deadlineBadge = event.registrationDeadline
  ? `Cierre ${dayMonth(event.registrationDeadline)}${
      event.registrationNote ? ` · ${event.registrationNote}` : ''
    }`
  : null;

// --- Cifras del recorrido (del GPX) --------------------------------------
interface RouteData {
  properties: {
    totalKm: number;
    elevation: { minM: number; maxM: number; gainM: number };
  };
}
const route = JSON.parse(routeRaw) as RouteData;
const { totalKm, elevation } = route.properties;

const nf = new Intl.NumberFormat('es-BO');
const eMin = elevation.minM;
const eMax = elevation.maxM;
---

<section id="recorrido" class="course">
  <div class="course__inner">
    <div class="course__grid">
      <div class="course__aside">
        <p class="eyebrow" data-reveal>// El recorrido</p>
        <h2 class="course__title" data-reveal data-delay="1">{title}</h2>

        <dl class="logi" data-reveal data-delay="2">
          {event.gatheringTime && (
            <div class="logi__row">
              <dt class="logi__k">Concentración</dt>
              <dd class="logi__v">{event.gatheringTime}</dd>
            </div>
          )}
          {partida && (
            <div class="logi__row">
              <dt class="logi__k">Partida</dt>
              <dd class="logi__v">{partida}</dd>
            </div>
          )}
          {meta && (
            <div class="logi__row">
              <dt class="logi__k">Meta</dt>
              <dd class="logi__v">{meta}</dd>
            </div>
          )}
        </dl>

        <dl class="course__stats" data-reveal data-delay="3">
          <div class="stat">
            <dt class="stat__k">Distancia</dt>
            <dd class="stat__v">{totalKm.toFixed(1)} <span class="stat__u">km</span></dd>
          </div>
          <div class="stat">
            <dt class="stat__k">Altitud</dt>
            <dd class="stat__v">
              {nf.format(Math.round(eMin))}–{nf.format(Math.round(eMax))} <span class="stat__u">m</span>
            </dd>
          </div>
          <div class="stat">
            <dt class="stat__k">Desnivel</dt>
            <dd class="stat__v">+{elevation.gainM} <span class="stat__u">m</span></dd>
          </div>
        </dl>

        {deadlineBadge && <p class="course__badge" data-reveal data-delay="3">{deadlineBadge}</p>}
      </div>

      <figure class="route" data-reveal data-delay="2">
        <Image
          class="route__img"
          src={routeMap}
          alt={`Mapa del recorrido oficial de ${title}: partida en ${event.location} y meta en ${meta ?? 'el centro de La Paz'}.`}
          widths={[600, 900, 1000]}
          sizes="(max-width: 899px) 100vw, 560px"
          loading="lazy"
        />
        <figcaption class="route__cap">Recorrido oficial · {totalKm.toFixed(1)} km</figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
  .course {
    background: var(--fl-cream-2);
    color: var(--fl-ink);
  }
  .course__inner {
    max-width: var(--fl-container);
    margin: 0 auto;
    padding: clamp(48px, 6vw, 88px) clamp(20px, 5vw, 56px);
  }

  /* --- Composición: texto+logística | mapa ------------------------------- */
  /* Móvil: apilado (texto arriba, mapa a ancho completo abajo). */
  .course__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(28px, 5vw, 52px);
    align-items: start;
  }
  /* Desktop: dos columnas; el mapa cuadrado llena su columna y se va la banda
     muerta que dejaba el cuadrado centrado en un marco más ancho. */
  @media (min-width: 900px) {
    .course__grid {
      grid-template-columns: minmax(0, 0.82fr) minmax(0, 1fr);
      gap: clamp(40px, 5vw, 72px);
      align-items: center;
    }
  }
  .course__aside {
    min-width: 0;
  }
  .eyebrow {
    margin: 0;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--fl-on-cream-faint);
  }
  .course__title {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(32px, 4.2vw, 52px);
    margin: 14px 0 0;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.96;
    text-wrap: balance;
  }
  /* Logística (concentración / partida / meta): filas etiqueta → valor que
     complementan el mapa con los datos exactos que en él no se leen. */
  .logi {
    margin: clamp(20px, 3vw, 28px) 0 0;
    display: flex;
    flex-direction: column;
    max-width: 460px;
  }
  .logi__row {
    display: grid;
    grid-template-columns: 116px 1fr;
    gap: 16px;
    padding: 13px 0;
    align-items: baseline;
  }
  .logi__row + .logi__row {
    border-top: 1px solid rgba(20, 35, 58, 0.1);
  }
  .logi__k {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--fl-on-cream-faint);
  }
  .logi__v {
    margin: 0;
    font-size: 15px;
    line-height: 1.4;
    color: var(--fl-ink);
  }
  .course__badge {
    display: inline-block;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    background: var(--fl-ink);
    color: var(--fl-cream);
    padding: 11px 18px;
    margin: 22px 0 0;
  }
  .course__stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(20px, 4vw, 40px);
    margin: clamp(24px, 3vw, 32px) 0 0;
  }
  .stat {
    margin: 0;
  }
  .stat__k {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--fl-on-cream-faint);
  }
  .stat__v {
    margin: 6px 0 0;
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(22px, 2.6vw, 30px);
    letter-spacing: -0.02em;
    color: var(--fl-ink);
  }
  .stat__u {
    font-size: 0.5em;
    color: var(--fl-orange);
    margin-left: 2px;
  }

  /* --- Mapa del recorrido oficial ---------------------------------------- */
  /* El mapa llena su columna; borde fino directamente sobre la imagen (sin mat
     crema, que se leía como passepartout heredado del placeholder). */
  .route {
    margin: 0;
  }
  .route__img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid rgba(20, 35, 58, 0.14);
  }
  .route__cap {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--fl-on-cream-muted);
    margin-top: 12px;
    text-align: center;
  }
</style>
