---
import type { EventData } from '../format';
import { shortDate } from '../format';

interface Props {
  event: EventData;
}
const { event } = Astro.props;

const [locMain, ...locRest] = event.location.split(',');
const locSub = [locRest.join(',').trim(), event.city].filter(Boolean).join(' · ');

const facts = [
  { label: 'Fecha', value: shortDate(event.date), sub: String(event.date.getUTCFullYear()) },
  event.gatheringTime && event.startTime
    ? {
        label: 'Horarios',
        value: `${event.gatheringTime} / ${event.startTime}`,
        sub: 'Concentración / Partida',
      }
    : null,
  { label: 'Partida', value: locMain.trim(), sub: locSub },
  event.distances.length
    ? { label: 'Distancia', value: event.distances.join(' · '), sub: 'Damas y Varones' }
    : null,
].filter((f): f is { label: string; value: string; sub: string } => Boolean(f));
---

<section class="facts">
  <div class="facts__inner">
    <p class="eyebrow" data-reveal>// Datos de la carrera</p>
    <div class="facts__grid">
      {
        facts.map((f, i) => (
          <div class="fact" data-reveal data-delay={String(i + 1)}>
            <div class="fact__label">{f.label}</div>
            <div class="fact__value">{f.value}</div>
            {f.sub && <div class="fact__sub">{f.sub}</div>}
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .facts {
    background: var(--fl-cream);
    color: var(--fl-ink);
  }
  .facts__inner {
    max-width: var(--fl-container);
    margin: 0 auto;
    padding: clamp(44px, 6vw, 76px) clamp(20px, 5vw, 56px);
  }
  .eyebrow {
    margin: 0 0 26px;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #9a8f78;
  }
  .facts__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 1px;
    background: rgba(20, 35, 58, 0.12);
  }
  .fact {
    background: var(--fl-cream);
    padding: 8px 26px;
  }
  .fact__label {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #9a8f78;
  }
  .fact__value {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(22px, 2.4vw, 30px);
    margin-top: 8px;
  }
  .fact__sub {
    font-size: 15px;
    color: #6b6456;
  }
</style>
