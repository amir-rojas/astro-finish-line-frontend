---
import type { EventData } from '../format';

interface Props {
  event: EventData;
}
const { event } = Astro.props;
const distance = event.distances[0] ?? '';
---

{
  event.categories.length > 0 && (
    <section id="categorias" class="cats">
      <div class="cats__inner">
        <div class="cats__head" data-reveal>
          <h2 class="cats__title">
            Categorías {distance && <span class="cats__hl">{distance}</span>}
          </h2>
          <p class="cats__kicker">Damas y Varones</p>
        </div>

        <div class="cats__grid">
          {event.categories.map((cat, i) => (
            <article class="cat" data-reveal data-delay={String(i + 1)}>
              <span class="cat__idx">{String(i + 1).padStart(2, '0')}</span>
              <div class="cat__body">
                <h3 class="cat__name">{cat.name}</h3>
                <p class="cat__ages">{cat.ages}</p>
              </div>
            </article>
          ))}
        </div>

        {event.categoriesNote && (
          <p class="cats__note" data-reveal>
            {event.categoriesNote}
          </p>
        )}
      </div>
    </section>
  )
}

<style>
  .cats {
    background: var(--fl-cream);
    color: var(--fl-ink);
  }
  .cats__inner {
    max-width: var(--fl-container);
    margin: 0 auto;
    padding: clamp(50px, 7vw, 88px) clamp(20px, 5vw, 56px);
  }
  .cats__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 30px;
  }
  .cats__title {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(34px, 4.4vw, 56px);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }
  .cats__hl {
    color: var(--fl-orange);
  }
  .cats__kicker {
    margin: 0;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #9a8f78;
  }

  /* Fila editorial: items separados por hairlines, sin cajas blancas. */
  .cats__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1px;
    background: rgba(20, 35, 58, 0.14);
    border-block: 1px solid rgba(20, 35, 58, 0.14);
  }
  .cat {
    background: var(--fl-cream);
    padding: 32px clamp(20px, 2.4vw, 30px) 36px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    transition:
      background-color 220ms var(--ease-out),
      color 220ms var(--ease-out);
  }
  .cat__idx {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(40px, 4.5vw, 56px);
    line-height: 0.8;
    letter-spacing: -0.03em;
    color: var(--fl-orange);
  }
  .cat__name {
    font-family: 'Archivo Black', sans-serif;
    font-size: 28px;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }
  .cat__ages {
    margin: 6px 0 0;
    font-size: 16px;
    color: #6b6456;
    transition: color 220ms var(--ease-out);
  }
  @media (hover: hover) {
    .cat:hover {
      background: var(--fl-navy);
      color: var(--fl-cream);
    }
    .cat:hover .cat__ages {
      color: #b9c6d6;
    }
  }
  .cats__note {
    margin: 18px 0 0;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.5px;
    color: #9a8f78;
  }
</style>
